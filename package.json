{
  "name": "playwright-recaptcha-solver",
  "version": "0.0.0",
  "description": "Solve reCAPTCHA v2 audio challenge using Playwright",
  "keywords": [
    "playwright",
    "recaptcha",
    "recaptcha-solver",
    "recaptcha-v2",
    "captcha",
    "captcha-solving",
    "automation",
    "typescript",
    "nodejs"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielgatis/playwright-recaptcha-solver.git"
  },
  "homepage": "https://github.com/danielgatis/playwright-recaptcha-solver#readme",
  "bugs": {
    "url": "https://github.com/danielgatis/playwright-recaptcha-solver/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.64.0"
  }
}
